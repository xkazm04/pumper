# Build artifacts
/target
# Example WASM plugins build in their own (detached) workspaces
plugins-src/*/target/
plugins-src/*/Cargo.lock

# Local runtime data: SQLite DB, scraped artifacts, browser profile (login cookies)
/data

# Claude Code session logs and local settings — but the shared session
# contract (CLAUDE.md) and the doc-sync Stop hook (settings.json) are
# versioned so every checkout gets the same enforcement.
.claude/*
!.claude/CLAUDE.md
!.claude/settings.json

# Secrets / local environment overrides
.env
*.local

# Editor / IDE
.idea/
.vscode/
*.swp
*~

# OS files
.DS_Store
Thumbs.db
